from fastapi.testclient import TestClient
from api.main import app

client = TestClient(app)


def test_fetch_staging_candidates():

    response = client.get("/candidates/staging")

    assert response.status_code == 200
    assert "count" in response.json()


def test_verify_candidate_success():

    response = client.post("/candidates/1/verify")

    assert response.status_code == 200
    assert "message" in response.json()


def test_verify_candidate_not_found():

    response = client.post("/candidates/999/verify")

    assert response.status_code == 200
    assert response.json()["message"] == "Candidate not found"